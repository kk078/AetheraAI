{
  "policy_name": "Aethera AI - Login Required (Email OTP)",
  "description": "Zero-trust Access policy for ai.aetherahealthcare.com. Only the listed email(s) can log in, via a one-time passcode, before any traffic reaches the app. This is a single-user deployment, so allowed_emails should contain just the owner's address.",
  "decision": "allow",
  "session_duration": "24h",
  "precedence": 1,
  "include": [
    {
      "type": "email",
      "value": "<YOUR_LOGIN_EMAIL>"
    }
  ],
  "require": [],
  "exclude": [],
  "applications": [
    {
      "name": "Aethera AI",
      "domain": "ai.aetherahealthcare.com",
      "type": "self_hosted",
      "session_duration": "24h",
      "auto_redirect_to_identity": true
    }
  ],
  "authentication_methods": [
    {
      "type": "email",
      "name": "Email OTP",
      "config": {
        "otp_length": 6,
        "otp_expiry_minutes": 10
      }
    }
  ],
  "allowed_emails": ["<YOUR_LOGIN_EMAIL>"],
  "allowed_email_domains": [],
  "ip_whitelist": [],
  "geo_restrictions": {
    "enabled": false,
    "allowed_countries": []
  },
  "device_posture": {
    "require_managed_device": false,
    "require_screen_lock": false,
    "require_disk_encryption": false
  }
}
