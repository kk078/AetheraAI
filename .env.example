# =============================================================================
# AETHERA AI — ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values:
#   Copy-Item .env.example .env
#   Then edit .env with your actual keys.
#
# Required keys are marked with [REQUIRED]
# Optional keys are marked with [OPTIONAL]
# Keys with defaults work out of the box but can be overridden
# =============================================================================

# =============================================================================
# ENCRYPTION & SECURITY — [REQUIRED]
# =============================================================================
# Generate a secure encryption key for PHI/PII data storage:
#   python -c "import secrets; print(secrets.token_hex(32))"
# This key encrypts sensitive data in SQLite (SQLCipher) and file storage.
# WARNING: Losing this key means losing access to all encrypted data.
ENCRYPTION_KEY=

# =============================================================================
# OLLAMA CLOUD — PRIMARY BRAIN [REQUIRED for cloud models]
# =============================================================================
# Aethera uses Ollama Cloud for frontier models (qwen3.5:122b, etc.)
# These run on Ollama's cloud GPUs — zero local resource usage.
#
# Get your API key: https://ollama.com/settings/api
#
# Plan recommendations:
#   Free tier: Limited sessions, good for testing
#   Pro ($20/mo): 3 concurrent models, sufficient for multi-agent reasoning
#   Max ($50/mo): 10 concurrent models, heavy usage
#
# Cloud models available:
#   qwen3.5:122b (L3)     — Primary brain, frontier intelligence
#   deepseek-v4-flash (L2) — 284B MoE, 1M context, deep reasoning
#   kimi-k2.6 (L3)        — Best coder, multimodal agentic
#   gemma4:26b (L2)       — Tool calling + vision
#   nemotron-3-super (L2)  — Efficient multi-agent (120B MoE, 12B active)
#   qwen3.5:35b (L2)      — Balanced speed/intelligence
#   glm-5.1 (L3)          — Agentic engineering
#   deepseek-v4-pro (L4)  — Frontier, use sparingly
OLLAMA_API_KEY=

# =============================================================================
# HUGGINGFACE — OVERFLOW CAPACITY [OPTIONAL]
# =============================================================================
# Used when Ollama Cloud quota is exhausted.
# Free tier: ~1000 requests/day without token, higher limits with free account.
# Get token: https://huggingface.co/settings/tokens
HF_TOKEN=

# =============================================================================
# CLOUDFLARE — INFRASTRUCTURE MANAGEMENT [OPTIONAL]
# =============================================================================
# For managing DNS, Tunnels, Access, Pages, Workers, R2 storage.
# Required for remote access via Cloudflare Tunnel (zero-trust security).
#
# Get API Token: https://dash.cloudflare.com/profile/api-tokens
#   Create token with: DNS edit, Tunnel edit, Access edit, Pages edit, Workers edit, R2 edit
# Account ID shown on Cloudflare dashboard right sidebar.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare Tunnel configuration (for remote access):
CLOUDFLARE_TUNNEL_NAME=aethera

# Public hostname Aethera is published at:
CLOUDFLARE_DOMAIN=ai.aetherahealthcare.com

# Tunnel token for the Docker cloudflared overlay (docker-compose.cloudflared.yml).
# Create a tunnel named "aethera" in Zero Trust > Networks > Tunnels and paste
# its connector token here. See docs/PUBLISH.md.
CLOUDFLARE_TUNNEL_TOKEN=

# Email allowed to LOG IN via Cloudflare Access (email one-time-passcode).
# Single-user: set this to your own address; only this email can sign in.
CLOUDFLARE_ACCESS_EMAIL=

# Dedicated Cloudflare resources for this app (non-PHI).
# These are config identifiers, not secrets. Created via the Cloudflare account
# named aethera-ai-*. Do NOT store PHI here without a Cloudflare BAA in place.
#   KV namespace for cascade rate-limit counters and non-PHI response cache:
CLOUDFLARE_KV_CACHE_ID=
#   R2 bucket for non-PHI artifacts (knowledge-base files, exports, static assets):
CLOUDFLARE_R2_ASSETS_BUCKET=aethera-ai-assets

# =============================================================================
# COMPLIANCE / SECURITY [OPTIONAL — required for PHI workloads]
# =============================================================================
# Bearer-key auth on /api/* (off by default). Set API_KEYS (comma-separated)
# and the frontend/clients must send: Authorization: Bearer <key>
API_AUTH_ENABLED=false
API_KEYS=
# Restrict CORS origins for PHI deployments (default "*" for local/dev):
CORS_ALLOW_ORIGINS=*
# Conversation retention policy (days) used by /api/compliance/retention/cleanup:
CONVERSATION_RETENTION_DAYS=2555
# Encrypt backups at rest (reuses ENCRYPTION_KEY if unset):
BACKUP_ENCRYPTION_KEY=
# Off-site encrypted backup upload to a BAA-covered R2 bucket (requires boto3):
BACKUP_R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# =============================================================================
# GITHUB — CODE INTEGRATION [OPTIONAL]
# =============================================================================
# For repo management, code review, CI/CD status, issue tracking.
# Create PAT: https://github.com/settings/tokens
# Scopes: repo, workflow, read:user, user:email
GITHUB_TOKEN=

# =============================================================================
# EMAIL — IMAP INTEGRATION [OPTIONAL]
# =============================================================================
# For email intelligence: auto-categorization, action extraction, draft replies.
# Uses IMAP (read-only by default, sending requires explicit approval).
#
# Common IMAP servers:
#   Gmail:    imap.gmail.com (requires App Password)
#   Outlook:  outlook.office365.com
#   Yahoo:    imap.mail.yahoo.com
IMAP_SERVER=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_USE_SSL=true

# =============================================================================
# TELEGRAM — PUSH NOTIFICATIONS [OPTIONAL]
# =============================================================================
# For instant notifications: alerts, morning briefing, action queue reminders.
# 1. Create bot: Message @BotFather on Telegram, send /newbot
# 2. Follow prompts to name bot and get token
# 3. Get your Chat ID: Message @userinfobot, it replies with your ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# CALENDAR — CALDAV INTEGRATION [OPTIONAL]
# =============================================================================
# For scheduling, meeting detection, free time lookup.
# Works with Google Calendar, Outlook, iCloud, any CalDAV server.
#
# Google Calendar: Use App Password, URL format:
#   https://www.google.com/calendar/dav/your_email@gmail.com/events
# Outlook: Use app password, URL:
#   https://outlook.office365.com/calendar/dav/your_email@outlook.com
CALDAV_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=

# =============================================================================
# CUSTOM LLM ENDPOINT — ADDITIONAL CAPACITY [OPTIONAL]
# =============================================================================
# Add any OpenAI-compatible API endpoint for extra model capacity.
# Examples: Groq, Cerebras, SambaNova, local Ollama on a different machine.
# After setting these, also add a model entry in litellm_config.yaml.
CUSTOM_API_BASE=
CUSTOM_MODEL_NAME=
CUSTOM_API_KEY=

# =============================================================================
# USER PREFERENCES
# =============================================================================
# Default specialist for ambiguous queries
# Options: provider, payer, regulatory, clinical, analytics, it, pharmacy,
#          behavioral, dental_vision, workers_comp, finance, legal,
#          software_engineering, media_marketing, research,
#          personal_assistant, cloudflare_ops, data_analytics, general
DEFAULT_SPECIALIST=general

# Model preference override (leave empty for automatic cascade selection)
# Options: aethera-cloud-brain, aethera-cloud-reason, aethera-cloud-coder,
#          aethera-cloud-tools, aethera-cloud-agent, aethera-cloud-balanced,
#          aethera-cloud-engineer, aethera-local-fast, aethera-local-tools,
#          aethera-local-smart
PREFERRED_MODEL=

# Location for weather in morning briefing (city name or lat,lon)
USER_LOCATION=

# Timezone for scheduling (IANA format)
USER_TIMEZONE=America/New_York

# Morning briefing time (cron format, "0 7 * * *" = 7 AM daily)
MORNING_BRIEFING_TIME=0 7 * * *

# PHI detection (NEVER disable for healthcare use)
PHI_DETECTION_ENABLED=true

# Audit logging (required for HIPAA compliance)
AUDIT_LOGGING_ENABLED=true

# =============================================================================
# ADVANCED / DEVELOPER
# =============================================================================
# Enable debug logging (verbose output in orchestrator)
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable Prometheus metrics endpoint
METRICS_ENABLED=false

# Rate limiting for API (requests per minute per IP)
RATE_LIMIT=60

# Session timeout in minutes
SESSION_TIMEOUT=120

# Maximum file upload size in MB
MAX_UPLOAD_SIZE=50

# Enable multi-agent reasoning for complex queries
MULTI_AGENT_ENABLED=true

# Enable proactive intelligence (morning briefing, alerts, automations)
PROACTIVE_ENABLED=true

# Enable voice features (STT/TTS)
VOICE_ENABLED=true

# Enable clipboard monitoring (Windows system tray agent)
CLIPBOARD_ENABLED=true

# =============================================================================
# INTERNAL SERVICE URLS (defaults work for Docker Compose setup)
# Do not change these unless you are running services on different hosts.
# =============================================================================
DATABASE_URL=sqlite+aiosqlite:///data/aethera.db
ENCRYPTED_DB_PATH=/data/aethera_encrypted.db
REDIS_URL=redis://redis:6379
CHROMADB_URL=http://chromadb:8000
LITELLM_URL=http://litellm:4000
OLLAMA_URL=http://ollama:11434
SEARXNG_URL=http://searxng:8080

# =============================================================================
# FRONTEND URLs (override if accessing from a different host)
# =============================================================================
# Local dev defaults:
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
# When PUBLISHING at your domain, set these to the public URL and rebuild the UI
# image (Vite bakes them at build time):
#   VITE_API_URL=https://ai.aetherahealthcare.com
#   VITE_WS_URL=wss://ai.aetherahealthcare.com/api/voice/stream